{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chemistry teacher knowledge item v1",
  "type": "object",
  "required": ["id", "subject", "question_text", "solution_text", "review_status", "confidence", "updated_at"],
  "properties": {
    "id": { "type": "string" },
    "subject": { "type": "string" },
    "chapter": { "type": "string" },
    "concepts": { "type": "array", "items": { "type": "string" } },
    "question_type": { "type": "string" },
    "question_text": { "type": "string" },
    "teacher_answer": { "type": "string" },
    "solution_text": { "type": "string" },
    "method_ids": { "type": "array", "items": { "type": "string" } },
    "review_status": { "enum": ["draft", "reviewed", "published"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "updated_at": { "type": "string" }
  }
}
